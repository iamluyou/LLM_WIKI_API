# LLM 配置（与 LLM-WIKI 桌面版对齐）
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
LLM_MODEL=glm-5.1
LLM_MAX_CONTEXT=262144
LLM_REASONING_MODE=max

# 输出语言
OUTPUT_LANGUAGE=Chinese

# Wiki 目录
WIKI_ROOT=./wiki_data

# 服务配置
HOST=0.0.0.0
PORT=6003
LOG_LEVEL=info

# Ingest 配置
INGEST_CONCURRENCY=1
INGEST_SAVE_TO_WIKI=true
INGEST_CACHE_ENABLED=true

# 向量搜索（可选）
EMBEDDING_ENABLED=false
EMBEDDING_MODEL=
EMBEDDING_API_KEY=
EMBEDDING_ENDPOINT=
